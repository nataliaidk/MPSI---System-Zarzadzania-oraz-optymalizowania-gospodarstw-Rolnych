    <bpmn:sequenceFlow id="Flow_4" sourceRef="Activity_Optymalizacja" targetRef="Gateway_Akceptacja" />
    <bpmn:sequenceFlow id="Flow_Tak" name="Wysłanie koszyka do akceptacji" sourceRef="Gateway_Akceptacja" targetRef="Activity_Zatwierdzenie" />
    <bpmn:sequenceFlow id="Flow_Nie" name="Czekaj na lepszą cenę" sourceRef="Gateway_Akceptacja" targetRef="Event_0i0dkt9" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Activity_Zatwierdzenie" targetRef="End_ZamowienieWyslane" />
