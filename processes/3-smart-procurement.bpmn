    <bpmn:sequenceFlow id="Flow_0q01wpk" name="Wyślij koszyk do akceptacji" sourceRef="Event_1798njl" targetRef="Activity_Zatwierdzenie" />
    <bpmn:endEvent id="End_ZamowienieWyslane" name="Zamówienie złożone">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="Event_1mej557" name="48 godziny" attachedToRef="Activity_Zatwierdzenie">
      <bpmn:outgoing>Flow_1remj9h</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_05qstba" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_1remj9h" name="po upływie czasu" sourceRef="Event_1mej557" targetRef="Event_1l7b5oz" />
