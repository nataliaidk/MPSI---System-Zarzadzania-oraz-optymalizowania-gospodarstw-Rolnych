  <bpmn:collaboration id="Collaboration_0">
    <bpmn:participant id="Participant_System" name="Zintegrowany System Zarządzania (FMIS)" processRef="Process_SmartProcurement" />
    <bpmn:participant id="Participant_Dystrybutor" name="Dystrybutorzy Agro (Systemy Zewnętrzne)" />
    <bpmn:messageFlow id="Flow_Message_Out" name="Zapytanie o ceny i dostępność" sourceRef="Activity_MonitorRynek" targetRef="Participant_Dystrybutor" />
    <bpmn:messageFlow id="Flow_Message_In" name="Cenniki i Dostępność" sourceRef="Participant_Dystrybutor" targetRef="Activity_MonitorRynek" />
  </bpmn:collaboration>
  <bpmn:process id="Process_SmartProcurement" isExecutable="true">
    <bpmn:laneSet id="LaneSet_0">
