        <bpmn:flowNodeRef>Event_0i0dkt9</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1798njl</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Zarzadca" name="Właściciel / Zaopatrzeniowiec">
