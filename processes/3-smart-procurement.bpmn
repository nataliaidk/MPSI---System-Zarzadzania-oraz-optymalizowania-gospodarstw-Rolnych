      <bpmn:incoming>Flow_Tak</bpmn:incoming>
      <bpmn:incoming>Flow_0q01wpk</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1m7ahqe" sourceRef="Event_0i0dkt9" targetRef="Activity_MonitorRynek" />
