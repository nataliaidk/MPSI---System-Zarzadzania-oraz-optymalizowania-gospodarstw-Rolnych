        <bpmn:flowNodeRef>Gateway_Akceptacja</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ZamowienieWyslane</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1l7b5oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1mej557</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_Sezon" targetRef="Activity_Prognozowanie" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_Prognozowanie" targetRef="Activity_MonitorRynek" />
