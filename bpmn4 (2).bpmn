<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Process4_StorageSales" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:dataStore id="DataStore_PriceHistory" name="Historia cen skupu" />
  <bpmn:dataStore id="DataStore_SiloInventory" name="Stan magazynowy i partie plonu" />
  <bpmn:collaboration id="Collaboration_Process4">
    <bpmn:participant id="Participant_MarketSources" name="Źródła cen skupu / systemy zewnętrzne" />
    <bpmn:participant id="Participant_00nbw7j" processRef="Process_084ga2g" />
    <bpmn:messageFlow id="MessageFlow_ReceivePrices" name="Aktualne ceny i trendy rynkowe" sourceRef="Participant_MarketSources" targetRef="ServiceTask_UpdatePriceHistoryAndAnalyze" />
    <bpmn:messageFlow id="MessageFlow_RequestPrices" name="Zapytanie o aktualne notowania" sourceRef="ServiceTask_RequestMarketPrices" targetRef="Participant_MarketSources" />
  </bpmn:collaboration>
  <bpmn:process id="Process_084ga2g">
    <bpmn:laneSet id="LaneSet_1xelfqe">
      <bpmn:lane id="Lane_1vdaxwh" name="System magazynowy / analityczny">
        <bpmn:flowNodeRef>Event_ConnectionRestored</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GenerateStorageAlert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StorageRisk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_MonitorSilo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_UpdateInventoryQuality</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_ValidateBatchAndAssign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_SyncDumpEntry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_SaveOfflineEntry</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_1mcjznj" name="Właściciel / Zarządca">
        <bpmn:flowNodeRef>EventSubProcess_PriceMonitoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ReviewStorageAlert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProcessClosed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_0r3hw5q" name="Operator / Aplikacja mobilna">
        <bpmn:flowNodeRef>Gateway_DeviceOnline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_RegisterHarvestDump</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_HarvestDelivery</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:dataStoreReference id="DataStoreReference_SiloInventory" name="Stan magazynowy" dataStoreRef="DataStore_SiloInventory" />
    <bpmn:intermediateCatchEvent id="Event_ConnectionRestored" name="Połączenie odzyskane">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:conditionalEventDefinition>
        <bpmn:condition xsi:type="bpmn:tFormalExpression">connectionAvailable = true</bpmn:condition>
      </bpmn:conditionalEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:dataStoreReference id="DataStoreReference_PriceHistory" name="Historia cen skupu" dataStoreRef="DataStore_PriceHistory" />
    <bpmn:dataObjectReference id="DataObjectReference_SalesRecommendation" name="Rekomendacja sprzedaży" dataObjectRef="DataObject_SalesRecommendation" />
    <bpmn:dataObject id="DataObject_SalesRecommendation" name="Rekomendacja sprzedaży" />
    <bpmn:serviceTask id="ServiceTask_GenerateStorageAlert" name="Wygeneruj alert magazynowy">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_StorageRisk" name="Czy występuje ryzyko pojemnościowe lub jakościowe?">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_MonitorSilo" name="Monitoruj poziom zapełnienia i wilgotność ziarna">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:property id="Property_0oonsro" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0t3nmdk">
        <bpmn:sourceRef>DataStoreReference_SiloInventory</bpmn:sourceRef>
        <bpmn:targetRef>Property_0oonsro</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_UpdateInventoryQuality" name="Zaktualizuj stan magazynowy i parametry partii">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1dyeb7c">
        <bpmn:targetRef>DataStoreReference_SiloInventory</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_ValidateBatchAndAssign" name="Zweryfikuj dane partii i przypisz do silosu">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_SyncDumpEntry" name="Synchronizuj wpis z systemem">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_SaveOfflineEntry" name="Zapisz wpis lokalnie w trybie offline">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_DeviceOnline" name="Czy urządzenie jest online?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_RegisterHarvestDump" name="Zarejestruj zrzut plonu do wirtualnego silosu">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_HarvestDelivery" name="Dostawa plonu z pola">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="ServiceTask_SaveOfflineEntry" targetRef="Event_ConnectionRestored" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Event_ConnectionRestored" targetRef="ServiceTask_SyncDumpEntry" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="ServiceTask_GenerateStorageAlert" targetRef="UserTask_ReviewStorageAlert" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="UserTask_ReviewStorageAlert" targetRef="EndEvent_ProcessClosed" />
    <bpmn:sequenceFlow id="Flow_12" name="Nie" sourceRef="Gateway_StorageRisk" targetRef="EndEvent_ProcessClosed" />
    <bpmn:sequenceFlow id="Flow_11" name="Tak" sourceRef="Gateway_StorageRisk" targetRef="ServiceTask_GenerateStorageAlert" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="ServiceTask_MonitorSilo" targetRef="Gateway_StorageRisk" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="ServiceTask_UpdateInventoryQuality" targetRef="ServiceTask_MonitorSilo" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="ServiceTask_ValidateBatchAndAssign" targetRef="ServiceTask_UpdateInventoryQuality" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="ServiceTask_SyncDumpEntry" targetRef="ServiceTask_ValidateBatchAndAssign" />
    <bpmn:sequenceFlow id="Flow_3" name="Tak" sourceRef="Gateway_DeviceOnline" targetRef="ServiceTask_SyncDumpEntry" />
    <bpmn:sequenceFlow id="Flow_4" name="Nie" sourceRef="Gateway_DeviceOnline" targetRef="ServiceTask_SaveOfflineEntry" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_RegisterHarvestDump" targetRef="Gateway_DeviceOnline" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_HarvestDelivery" targetRef="UserTask_RegisterHarvestDump" />
    <bpmn:subProcess id="EventSubProcess_PriceMonitoring" name="Ciągłe monitorowanie cen skupu" triggeredByEvent="true">
      <bpmn:sequenceFlow id="SubFlow_10" sourceRef="UserTask_OrderSale" targetRef="EndEvent_SaleOrdered" />
      <bpmn:sequenceFlow id="SubFlow_8" name="Tak" sourceRef="Gateway_ApproveSale" targetRef="UserTask_OrderSale" />
      <bpmn:sequenceFlow id="SubFlow_9" name="Nie" sourceRef="Gateway_ApproveSale" targetRef="EndEvent_SaleDeferred" />
      <bpmn:sequenceFlow id="SubFlow_7" sourceRef="UserTask_ReviewSalesRecommendation" targetRef="Gateway_ApproveSale" />
      <bpmn:sequenceFlow id="SubFlow_6" sourceRef="ServiceTask_GenerateSalesRecommendation" targetRef="UserTask_ReviewSalesRecommendation" />
      <bpmn:sequenceFlow id="SubFlow_4" name="Nie" sourceRef="Gateway_SalesOpportunity" targetRef="EndEvent_NoOpportunity" />
      <bpmn:sequenceFlow id="SubFlow_5" name="Tak" sourceRef="Gateway_SalesOpportunity" targetRef="ServiceTask_GenerateSalesRecommendation" />
      <bpmn:sequenceFlow id="SubFlow_3" sourceRef="ServiceTask_UpdatePriceHistoryAndAnalyze" targetRef="Gateway_SalesOpportunity" />
      <bpmn:sequenceFlow id="SubFlow_2" sourceRef="ServiceTask_RequestMarketPrices" targetRef="ServiceTask_UpdatePriceHistoryAndAnalyze" />
      <bpmn:sequenceFlow id="SubFlow_1" sourceRef="StartEvent_TimerPriceCheck" targetRef="ServiceTask_RequestMarketPrices" />
      <bpmn:endEvent id="EndEvent_SaleOrdered" name="Sprzedaż zlecona">
        <bpmn:incoming>SubFlow_10</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="EndEvent_SaleDeferred" name="Sprzedaż odroczona">
        <bpmn:incoming>SubFlow_9</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="EndEvent_NoOpportunity" name="Brak alertu sprzedażowego">
        <bpmn:incoming>SubFlow_4</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:userTask id="UserTask_OrderSale" name="Zleć sprzedaż partii plonu">
        <bpmn:incoming>SubFlow_8</bpmn:incoming>
        <bpmn:outgoing>SubFlow_10</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="Gateway_ApproveSale" name="Czy zatwierdzić sprzedaż?">
        <bpmn:incoming>SubFlow_7</bpmn:incoming>
        <bpmn:outgoing>SubFlow_9</bpmn:outgoing>
        <bpmn:outgoing>SubFlow_8</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:userTask id="UserTask_ReviewSalesRecommendation" name="Przejrzyj rekomendację sprzedaży">
        <bpmn:incoming>SubFlow_6</bpmn:incoming>
        <bpmn:outgoing>SubFlow_7</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="ServiceTask_GenerateSalesRecommendation" name="Wygeneruj rekomendację sprzedaży">
        <bpmn:incoming>SubFlow_5</bpmn:incoming>
        <bpmn:outgoing>SubFlow_6</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:exclusiveGateway id="Gateway_SalesOpportunity" name="Czy cena przekracza próg opłacalności?">
        <bpmn:incoming>SubFlow_3</bpmn:incoming>
        <bpmn:outgoing>SubFlow_5</bpmn:outgoing>
        <bpmn:outgoing>SubFlow_4</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:serviceTask id="ServiceTask_UpdatePriceHistoryAndAnalyze" name="Zaktualizuj historię cen i przeanalizuj opłacalność">
        <bpmn:incoming>SubFlow_2</bpmn:incoming>
        <bpmn:outgoing>SubFlow_3</bpmn:outgoing>
        <bpmn:property id="Property_1xjfy0v" name="__targetRef_placeholder" />
        <bpmn:dataInputAssociation id="DataInputAssociation_0pwn3a9">
          <bpmn:sourceRef>DataStoreReference_SiloInventory</bpmn:sourceRef>
          <bpmn:targetRef>Property_1xjfy0v</bpmn:targetRef>
        </bpmn:dataInputAssociation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="ServiceTask_RequestMarketPrices" name="Pobierz aktualne ceny skupu">
        <bpmn:incoming>SubFlow_1</bpmn:incoming>
        <bpmn:outgoing>SubFlow_2</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:startEvent id="StartEvent_TimerPriceCheck" name="Cykl monitoringu cen" isInterrupting="false">
        <bpmn:outgoing>SubFlow_1</bpmn:outgoing>
        <bpmn:timerEventDefinition>
          <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT1H</bpmn:timeCycle>
        </bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:association id="Association_Recommendation_Input" sourceRef="DataObjectReference_SalesRecommendation" targetRef="UserTask_ReviewSalesRecommendation" />
      <bpmn:association id="Association_Recommendation_Output" sourceRef="ServiceTask_GenerateSalesRecommendation" targetRef="DataObjectReference_SalesRecommendation" />
      <bpmn:association id="Association_PriceHistory_ReadWrite" sourceRef="ServiceTask_UpdatePriceHistoryAndAnalyze" targetRef="DataStoreReference_PriceHistory" />
    </bpmn:subProcess>
    <bpmn:userTask id="UserTask_ReviewStorageAlert" name="Przejrzyj alert magazynowy">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_ProcessClosed" name="Proces zakończony">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
